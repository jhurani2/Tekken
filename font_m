module font_m(
    input logic pix_clk,
    input logic vsync,
    input logic reset,
	input logic [9:0] DrawX, DrawY,
	input logic blank,
	input logic paul_char1, paul_char2, king_char1, king_char2, nina_char1,
    input logic nina_char2,ling_char1, ling_char2,
	input logic [7:0] keycode0, keycode1,
	output logic [3:0] red, green, blue,
	output logic font_bound,
	output logic timer_start,
	output logic [5:0] countdown_timer

);

logic [15:0] rom_address, rom_address_ff, rom_address_comb;
logic [1:0] rom_q, rom_q2;
logic [5:0] out, count;
logic [3:0] palette_red, palette_green, palette_blue, palette_red2, palette_green2, palette_blue2;
logic signed [10:0] font_lx, font_ly;
logic signed [10:0] name1_lx, name1_ly;
logic signed [10:0] name2_lx, name2_ly;
logic negedge_vga_clk;


localparam SPRITE_W = 32;
localparam SPRITE_H = 48;
localparam SPRITE_X = 295;
localparam SPRITE_Y = 230;
localparam SHEET_W = 23*32;

// where character 1's name starts (top left corner)
localparam CHAR1_NAME_X = 20;
localparam CHAR1_NAME_Y = 50;
localparam CHAR1_NAME_L = 32;
localparam CHAR1_NAME_H = 16;

// where character 2's name ends (top right corner)
localparam CHAR2_NAME_X = 620;
localparam CHAR2_NAME_Y = 50;
localparam CHAR2_NAME_L = 32;
localparam CHAR2_NAME_H = 16;

// read from ROM on negedge, set pixel on posedge
assign negedge_vga_clk = ~pix_clk;
assign font_lx = {1'b0, DrawX} - {1'b0, SPRITE_X};
assign font_ly = {1'b0, DrawY} - {1'b0, SPRITE_Y};
assign name1_lx = {1'b0, DrawX} - {1'b0, CHAR1_NAME_X};
assign name1_ly = {1'b0, DrawY} - {1'b0, CHAR1_NAME_Y};
assign name2_lx = {1'b0, DrawX} - {1'b0, CHAR2_NAME_X};
assign name2_ly = {1'b0, DrawY} - {1'b0, CHAR2_NAME_Y};
// address into the rom = (x*xDim)/640 + ((y*yDim)/480) * xDim
// this will stretch out the sprite across the entire screen
//assign rom_address = ((DrawX * 736) / 640) + (((DrawY * 48) / 480) * 736);

always_ff @ (posedge vsync)
    begin
        if ( reset  || keycode0 == 8'h15 || keycode1 == 8'h15) 
           begin
                timer_start <= 1'b0;
                out <= 6'd4;
                count <= 6'd60;
                //rom_address_ff <=( 8 * SPRITE_W) + ((font_ly >> 2) * SHEET_W) + ((font_lx >> 2)% SPRITE_W);
           end
        else
            begin
                if (count == 0)
                    begin
                    out <= out-1;
                    count <= 6'd60;
                   // rom_address_ff <= 16'b0;
                   if(out == 6'd1) //cite idea from claaude
                        timer_start <= 1'b1;
                    end
                else
                begin
                    count <= count-1;
//                        if(count == 6'd3) 
//                             rom_address_ff <=( 9 * SPRITE_W) + ((font_ly >> 2) * SHEET_W) + ((font_lx >> 2)% SPRITE_W);
//                        else if (count == 6'd2)
//                             rom_address_ff <=( 10 * SPRITE_W) + ((font_ly >> 2) * SHEET_W) + ((font_lx >> 2)% SPRITE_W);
//                        else if (count == 6'd1)
//                        begin
//                             if((DrawX >= SPRITE_X) && (DrawX <= SPRITE_X + 32))
//                                rom_address_ff <=( 6 * SPRITE_W) + ((font_ly >> 2) * SHEET_W) + ((font_lx >> 2)% SPRITE_W);
//                             else if ((DrawX > SPRITE_X + 32) && (DrawX <= SPRITE_X + 64))
//                                rom_address_ff <=( 11 * SPRITE_W) + ((font_ly >> 2) * SHEET_W) + ((font_lx >> 2)% SPRITE_W);
//                                timer_start <= 1'b1;
//                        end
                    
                end
        end
    end
    

assign countdown_timer = out;
always_comb //CITE!!!
begin
    rom_address_ff = 16'b0;
    if ((DrawX >= SPRITE_X) && (DrawX < SPRITE_X + SPRITE_W*2) && 
                          (DrawY >= SPRITE_Y) && (DrawY < SPRITE_Y + SPRITE_H*4))
    begin
        if (out == 6'd4)
            rom_address_ff = (8 * SPRITE_W) + ((font_ly >> 2) * SHEET_W) + ((font_lx >> 2) % SPRITE_W);
        else if (out == 6'd3)
            rom_address_ff = (9 * SPRITE_W) + ((font_ly >> 2) * SHEET_W) + ((font_lx >> 2) % SPRITE_W);
        else if (out == 6'd2)
            rom_address_ff = (10 * SPRITE_W) + ((font_ly >> 2) * SHEET_W) + ((font_lx >> 2) % SPRITE_W);
        else if (out == 6'd1)
        begin
            if (DrawX < SPRITE_X + SPRITE_W)
                rom_address_ff = (6 * SPRITE_W) + ((font_ly >> 2) * SHEET_W) + ((font_lx >> 2) % SPRITE_W);
            else
                rom_address_ff = (11 * SPRITE_W) + ((font_ly >> 2) * SHEET_W) + ((font_lx >> 2) % SPRITE_W);
        end
    end
end
always_comb
begin
    rom_address_comb = 16'b0;
    if(paul_char1)
    begin
       if((DrawX >= CHAR1_NAME_X) && (DrawX < (CHAR1_NAME_X + 8)))
            rom_address_comb = (0 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);
       else if ((DrawX >= (CHAR1_NAME_X + 8))&&(DrawX < (CHAR1_NAME_X + 16)))
            rom_address_comb = (1 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);
       else if ((DrawX >= (CHAR1_NAME_X + 16))&&(DrawX < (CHAR1_NAME_X + 24)))
            rom_address_comb = (2 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);
       else if ((DrawX >= (CHAR1_NAME_X + 24))&&(DrawX <= (CHAR1_NAME_X + 32)))
            rom_address_comb = (3 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);    
    end    
    else if(paul_char2)
    begin
       if((DrawX >= CHAR2_NAME_X) && (DrawX < (CHAR2_NAME_X + 8)))
            rom_address_comb = (0 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);
       else if ((DrawX >= (CHAR2_NAME_X + 8))&&(DrawX < (CHAR2_NAME_X + 16)))
            rom_address_comb = (1 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);
       else if ((DrawX >= (CHAR2_NAME_X + 16))&&(DrawX < (CHAR2_NAME_X + 24)))
            rom_address_comb = (2 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);
       else if ((DrawX >= (CHAR2_NAME_X + 24))&&(DrawX <= (CHAR2_NAME_X + 32)))
            rom_address_comb = (3 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);    
    end  
    else if(king_char1)
    begin
       if((DrawX >= CHAR1_NAME_X) && (DrawX < (CHAR1_NAME_X + 8)))
            rom_address_comb = (7 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);
       else if ((DrawX >= (CHAR1_NAME_X + 8))&&(DrawX < (CHAR1_NAME_X + 16)))
            rom_address_comb = (5 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);
       else if ((DrawX >= (CHAR1_NAME_X + 16))&&(DrawX < (CHAR1_NAME_X + 24)))
            rom_address_comb = (4 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);
       else if ((DrawX >= (CHAR1_NAME_X + 24))&&(DrawX <= (CHAR1_NAME_X + 32)))
            rom_address_comb = (6 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);    
    end 
    else if(king_char2)
    begin
       if((DrawX >= CHAR2_NAME_X) && (DrawX < (CHAR2_NAME_X + 8)))
            rom_address_comb = (7 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);
       else if ((DrawX >= (CHAR2_NAME_X + 8))&&(DrawX < (CHAR2_NAME_X + 16)))
            rom_address_comb = (5 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);
       else if ((DrawX >= (CHAR2_NAME_X + 16))&&(DrawX < (CHAR2_NAME_X + 24)))
            rom_address_comb = (4 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);
       else if ((DrawX >= (CHAR2_NAME_X + 24))&&(DrawX <= (CHAR2_NAME_X + 32)))
            rom_address_comb = (6 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);    
    end 
    else if(ling_char1)
    begin
       if((DrawX >= CHAR1_NAME_X) && (DrawX < (CHAR1_NAME_X + 8)))
            rom_address_comb = (3 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);
       else if ((DrawX >= (CHAR1_NAME_X + 8))&&(DrawX < (CHAR1_NAME_X + 16)))
            rom_address_comb = (5 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);
       else if ((DrawX >= (CHAR1_NAME_X + 16))&&(DrawX < (CHAR1_NAME_X + 24)))
            rom_address_comb = (4 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);
       else if ((DrawX >= (CHAR1_NAME_X + 24))&&(DrawX <= (CHAR1_NAME_X + 32)))
            rom_address_comb = (6 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);    
    end 
    else if(ling_char2)
    begin
       if((DrawX >= CHAR2_NAME_X) && (DrawX < (CHAR2_NAME_X + 8)))
            rom_address_comb = (3 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);
       else if ((DrawX >= (CHAR2_NAME_X + 8))&&(DrawX < (CHAR2_NAME_X + 16)))
            rom_address_comb = (5 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);
       else if ((DrawX >= (CHAR2_NAME_X + 16))&&(DrawX < (CHAR2_NAME_X + 24)))
            rom_address_comb = (4 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);
       else if ((DrawX >= (CHAR2_NAME_X + 24))&&(DrawX <= (CHAR2_NAME_X + 32)))
            rom_address_comb = (6 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);    
    end
    else if(nina_char1)
    begin
       if((DrawX >= CHAR1_NAME_X) && (DrawX < (CHAR1_NAME_X + 8)))
            rom_address_comb = (4 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);
       else if ((DrawX >= (CHAR1_NAME_X + 8))&&(DrawX < (CHAR1_NAME_X + 16)))
            rom_address_comb = (5 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);
       else if ((DrawX >= (CHAR1_NAME_X + 16))&&(DrawX < (CHAR1_NAME_X + 24)))
            rom_address_comb = (4 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);
       else if ((DrawX >= (CHAR1_NAME_X + 24))&&(DrawX <= (CHAR1_NAME_X + 32)))
            rom_address_comb = (1 * SPRITE_W) + ((name1_ly >> 2) * SHEET_W) + ((name1_lx % 8)* 4);    
    end 
    else if(nina_char2)
    begin
       if((DrawX >= CHAR2_NAME_X) && (DrawX < (CHAR2_NAME_X + 8)))
            rom_address_comb = (4 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);
       else if ((DrawX >= (CHAR2_NAME_X + 8))&&(DrawX < (CHAR2_NAME_X + 16)))
            rom_address_comb = (5 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);
       else if ((DrawX >= (CHAR2_NAME_X + 16))&&(DrawX < (CHAR2_NAME_X + 24)))
            rom_address_comb = (4 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);
       else if ((DrawX >= (CHAR2_NAME_X + 24))&&(DrawX <= (CHAR2_NAME_X + 32)))
            rom_address_comb = (1 * SPRITE_W) + ((name2_ly >> 2) * SHEET_W) + ((name2_lx % 8)* 4);    
    end 
  
        
end
    
//assign rom_address = (out != 0) ? rom_address_ff  : rom_address_comb; //cite idea from claude

always_comb
begin
    if (blank)
        begin
           if ((DrawX >= SPRITE_X) && (DrawY >= SPRITE_Y))
                begin
                red = palette_red;
                green = palette_green;
                blue = palette_blue;
                end
            else
                begin
                red = palette_red2;
                green = palette_green2;
                blue = palette_blue2;
                end
        end
    else
        begin
        red = 4'h0;
        green = 4'h0;
        blue = 4'h0;
        end
end

assign font_bound = (((DrawX >= SPRITE_X) && (DrawX <= SPRITE_X + 2*SPRITE_W) && (DrawY >= SPRITE_Y) && (DrawY <= SPRITE_Y + SPRITE_H))
                    || ((DrawX >= CHAR1_NAME_X) && (DrawX <= CHAR1_NAME_X + 4*CHAR1_NAME_L) && (DrawY >= CHAR1_NAME_Y) && (DrawY <= CHAR1_NAME_Y + CHAR1_NAME_H))
                    ||((DrawX >= CHAR2_NAME_X) && (DrawX <= CHAR2_NAME_X + 4*CHAR2_NAME_L) && (DrawY >= CHAR2_NAME_Y) && (DrawY <= CHAR2_NAME_Y + CHAR2_NAME_H)));
                    //(rom_address != 16'b0);

fontm_rom Font_rom (
	.clock   (negedge_vga_clk),
	.address1 (rom_address_ff),
	.address2 (rom_address_comb),
	.q1       (rom_q),
	.q2       (rom_q2)
);

font_palette Font_palette (
	.index (rom_q),
	.index2(rom_q2),
	.red   (palette_red),
	.green (palette_green),
	.blue  (palette_blue),
	.red2   (palette_red2),
	.green2 (palette_green2),
	.blue2  (palette_blue2)
);

endmodule
